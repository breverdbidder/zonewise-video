{
  "name": "zonewise-video",
  "version": "1.0.0",
  "description": "ZoneWise 3-minute GTM demo video built with Remotion",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render src/index.ts ZoneWiseDemo out/zonewise-demo.mp4 --fps=30",
    "render": "remotion render src/index.ts ZoneWiseDemo out/zonewise-demo.mp4 --fps=30",
    "render-hook-gif": "remotion render src/index.ts ZoneWiseHook out/hook.mp4 --fps=30 && ffmpeg -i out/hook.mp4 -vf 'fps=15,scale=1280:-1:flags=lanczos,split[s0][s1];[s0]palettegen[p];[s1][p]paletteuse' out/hook.gif"
  },
  "dependencies": {
    "@react-three/drei": "^9.99.0",
    "@react-three/fiber": "^8.15.0",
    "gsap": "^3.12.5",
    "remotion": "^4.0.180",
    "three": "^0.162.0"
  },
  "devDependencies": {
    "@remotion/bundler": "^4.0.180",
    "@remotion/cli": "^4.0.180",
    "@remotion/renderer": "^4.0.180",
    "@types/react": "^18.2.0",
    "@types/three": "^0.162.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.0.0"
  }
}
